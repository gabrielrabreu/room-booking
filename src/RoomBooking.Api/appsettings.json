{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj} {NewLine}{Exception}"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "BookingsDb": "",
    "ReportingDb": "",
    "RoomsDb": "",
    "UsersDb": ""
  }
}
